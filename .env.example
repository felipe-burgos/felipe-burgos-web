# Copy to .env.local for local dev. On Netlify: Site → Environment variables.
# Restart `npm run dev` after changing env vars.

# ── Public (VITE_* → embedded in client bundle) ─────────────────────────────

VITE_SITE_URL=https://felipeburgos.org
VITE_CONTACT_PROVIDER=resend
VITE_CONTACT_EMAIL=felipeminitry@gmail.com
VITE_CONTACT_PHONE=956 620 4546

# ── Resend (server-only — NEVER prefix with VITE_) ───────────────────────────
# https://resend.com — API key from dashboard

RESEND_API_KEY=re_your_api_key_here
# Testing: onboarding@resend.dev (only sends to your Resend account email)
# Production: contacto@felipeburgos.org after verifying the domain in Resend
RESEND_FROM_EMAIL=contacto@felipeburgos.org
# Inbox where the pastor receives form submissions
CONTACT_TO_EMAIL=felipeminitry@gmail.com

# ── Optional: Web3Forms / Formspree (client-side providers) ───────────────────

# VITE_WEB3FORMS_ACCESS_KEY=
# VITE_FORMSPREE_FORM_ID=
# VITE_CONTACT_PROVIDER=web3forms
